# ============================================================
# WeCord — 微信公众号 → Discord 桥接服务
# ============================================================
# 复制此文件为 .env 并填入实际值

# ── Discord Webhook ──────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# ── DeepSeek API（用于生成英文摘要）───────────────────────────
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Gist 服务（本地的 Gist 阅读器）───────────────────────────
# 桥接服务会用此凭据登录 Gist 来查找文章，生成 Gist 阅读链接
GIST_BASE_URL=http://gist:8080
GIST_USERNAME=your_gist_username
GIST_PASSWORD=your_gist_password

# ── 目标公众号在 Gist 中的 Feed ID ───────────────────────────
# 在 Gist 中订阅 we-mp-rss 的 RSS 源后，从浏览器地址栏获取 feed ID
# 例如 http://localhost:8080/#/feeds/123456 → Feed ID 为 123456
GIST_FEED_ID=your_feed_id_here

# ── 摘要长度（英文字符数）────────────────────────────────────
MAX_SUMMARY_CHARS=300
