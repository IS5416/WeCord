# ============================================================
# WeCord — 微信公众号 → Discord 桥接服务
# ============================================================
# 复制此文件为 .env 并填入实际值

# ── Discord Webhook ──────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# ── Gist 服务 ────────────────────────────────────────────────
# GIST_BASE_URL: 容器内网地址（bridge 调 API 用）
GIST_BASE_URL=http://gist:8080
# GIST_PUBLIC_URL: Discord 用户可访问的公网地址
# 本地测试用 localhost，内网穿透/公网部署时改为实际域名
GIST_PUBLIC_URL=http://localhost:8080
GIST_USERNAME=your_gist_username
GIST_PASSWORD=your_gist_password

# ── 目标公众号在 Gist 中的 Feed ID ───────────────────────────
# 在 Gist 中订阅 we-mp-rss 的 RSS 源后，从浏览器地址栏获取
# 例如 http://localhost:8080/#/feeds/123456 → 123456
GIST_FEED_ID=your_feed_id_here

# ── we-mp-rss 集成（可选，用于自动修复短内容）─────────────────
# 在 we-mp-rss UI → 访问密钥 → 生成 AK/SK，填入下方
WERSS_BASE_URL=http://we-mp-rss:8001
WERSS_AK=
WERSS_SK=

# ── 摘要长度（英文字符数）────────────────────────────────────
MAX_SUMMARY_CHARS=300

# ============================================================
# 注意：DeepSeek API 在 Gist Web UI 中配置（不在本文件）
# 访问 http://localhost:8080 → Settings → AI
# 将 Summary Language 设为 English 以获取英文摘要
# ============================================================
